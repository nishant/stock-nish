# ─── Schwab Trader API ────────────────────────────────────────────────────────
# OAuth 2.0 access token from Schwab Developer Portal.
# Without this, the app returns mock data.
# Obtain via: https://developer.schwab.com → Your App → OAuth flow
SCHWAB_ACCESS_TOKEN=

# Optional: override the default port (3001)
# PORT=3001
